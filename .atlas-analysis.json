  "keyFeatures": [
    "AI-powered project planning with Gemini 3 Pro generating phased, dependency-aware task graphs",
    "Isolated E2B sandbox execution running Gemini CLI in YOLO mode for autonomous coding",
    "Automatic GitHub PR creation for every completed task with diff review in-platform",
    "Real-time execution streaming via Upstash Realtime for live logs and status updates",
    "Human-in-the-loop review flow: approve, request changes, or merge PRs from mission control UI",
    "Task state machine with retry logic (PENDING → RUNNING → REVIEW/FAILED → DONE)",
    "Gemini 3 Flash for quick idea previews; Gemini 3 Pro for deep planning",
    "Secret redaction and secure sandbox orchestration with strict guardrails"
  ],
  "publicApiSurface": [
