    "getProjectStats / updateProjectStatus",
    "startProjectPreview / resetProjectPreview / getProjectFileTree / getProjectFileContent",
    "getPreview (preview agent)",
    "transcribe (voice-to-text input)",
    "startExecution / stopExecution",
    "getReviewPRList / getReviewPRSummary / getReviewPRFiles / mergePullRequest",
    "startTask / completeTask / getNextRunnableTask / isProjectRunning (orchestrator)",
    "executeGeminiStreaming / executeCommand / getOrCreateProjectSandbox (sandbox provider)"
  ]
